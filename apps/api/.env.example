# ============================================================
# Pharmacy Near-Expiry Marketplace — API Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME="Pharmacy Near-Expiry Marketplace"
APP_ENV=development          # development | staging | production
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-me-use-openssl-rand-hex-32

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pharmacy_marketplace
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins. No wildcard in production.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Security Guards ───────────────────────────────────────────
# Set to true in production to enforce Cloudflare proxy headers
REQUIRE_CLOUDFLARE=false
# Comma-separated CIDR list of allowed Cloudflare IPs (empty = any)
CLOUDFLARE_ALLOWED_IPS=

# Set to true to enforce Firebase App Check tokens
REQUIRE_APPCHECK=false

# ── Firebase App Check ────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_APP_CHECK_PUBLIC_KEYS_URL=https://firebaseappcheck.googleapis.com/v1/jwks

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
NOLOG=false

# ── File Storage ──────────────────────────────────────────────
STORAGE_BACKEND=local        # local | s3
STORAGE_LOCAL_PATH=/tmp/uploads
AWS_S3_BUCKET=
AWS_S3_REGION=me-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MAX_UPLOAD_SIZE_MB=10

# ── Email ─────────────────────────────────────────────────────
EMAIL_BACKEND=stub            # stub | resend | smtp
RESEND_API_KEY=
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@pharmacy-marketplace.sa

# ── WhatsApp ─────────────────────────────────────────────────
WHATSAPP_BACKEND=stub         # stub | meta
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=

# ── Scheduler ────────────────────────────────────────────────
NEAR_EXPIRY_SCAN_INTERVAL_HOURS=6
# Comma-separated day thresholds for near-expiry notifications
NEAR_EXPIRY_THRESHOLDS_DAYS=180,90,30

# ── Frontend URL (used in email links) ───────────────────────
FRONTEND_URL=http://localhost:3000
